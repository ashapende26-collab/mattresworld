#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=bddefgdffdfs83rgvhr43xe

# ── CORS ────────────────────────────────────────────────────────────────────────
# Your Netlify site URL (no trailing slash)
FRONTEND_URL=https://your-site.netlify.app

# ── Environment ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
